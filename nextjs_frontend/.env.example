# Public URLs used by the frontend (safe to expose in browser)
# FastAPI base URL (browser-accessible)
NEXT_PUBLIC_API_BASE=http://localhost:3001
# Legacy alias supported by the client
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Frontend origin (useful if you set CORS_ALLOW_ORIGINS explicitly on backend)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# This app does not currently use websockets; keep unset unless you add WS features.
# NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
